# =============================================================================
# PollDriver — plantilla de variables
# =============================================================================
# Admin web: copia este bloque a apps/admin-web/.env.local
# (valores reales = mismos que el-pollon/.env para URL y anon key)
#
# NUNCA subas .env.local ni la service role key a Git / Vercel públicos.
# =============================================================================

# Obligatorias — mismo proyecto Supabase que El Pollón
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_o_publishable_key

# App
VITE_APP_NAME=PollDriver
VITE_EL_POLLON_URL=https://el-pollon.cl

# Mapa (MapLibre)
VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Solo scripts/Edge (NUNCA en el navegador ni en VITE_*)
# SUPABASE_SERVICE_ROLE_KEY=
